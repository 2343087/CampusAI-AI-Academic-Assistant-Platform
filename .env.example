# General
NODE_ENV=development

# Database
POSTGRES_USER=campusai
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=campusai_db
DATABASE_URL=postgresql+psycopg://postgres:your_db_password_here@localhost:5432/campusai

# Redis
REDIS_URL=redis://localhost:6379/0

# AI
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_API_KEY=your-google-api-key-here
CHROMA_URL=http://localhost:8001

# Security
SECRET_KEY=generate-with-python-secrets-token_hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Dev Console
DEV_ACCESS_TOKEN=change-this-token

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
